{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {
    "ENABLE_TOOL_SEARCH": "true"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git remote*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(shellcheck*)",
      "Bash(npx markdownlint-cli2*)",
      "Bash(prettier*)",
      "Bash(npx prettier*)",
      "Bash(pre-commit run*)",
      "Bash(pwsh*Invoke-ScriptAnalyzer*)",
      "Bash(npx *)",
      "Bash(npm list*)",
      "Bash(npm outdated*)",
      "Bash(bunx*)",
      "Bash(ls*)",
      "Bash(tree*)",
      "Bash(file *)",
      "Bash(wc*)",
      "Bash(stat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(cat*)",
      "Bash(uv run*)",
      "Bash(uv add*)",
      "Bash(uv remove*)",
      "Bash(uv sync*)",
      "Bash(uv lock*)",
      "Bash(uv tool*)",
      "Bash(uv pip*)",
      "Bash(uvx*)"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": "opus",
  "effortLevel": "high",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  }
}
