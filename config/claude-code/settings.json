{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": false,
  "env": {},
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(sort:*)",
      "Bash(grep:*)",
      "Bash(tr:*)",
      "Bash(tree*)",
      "Bash(file *)",
      "Bash(stat*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git remote*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git stash*)",
      "Bash(shellcheck*)",
      "Bash(npx markdownlint-cli2*)",
      "Bash(prettier*)",
      "Bash(npx prettier*)",
      "Bash(pre-commit run*)",
      "Bash(pwsh*Invoke-ScriptAnalyzer*)",
      "Bash(npx *)",
      "Bash(npm *)",
      "Bash(bunx *)",
      "Bash(uv *)",
      "Bash(uvx *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "effortLevel": "high",
  "alwaysThinkingEnabled": true,
  "autoMemoryEnabled": false,
  "outputStyle": "Explanatory",
  "skipDangerousModePermissionPrompt": true,
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "$HOME/.claude/hooks/uv.sh" }]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/managed-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "$HOME/.claude/hooks/sh.sh" },
          { "type": "command", "command": "$HOME/.claude/hooks/md.sh" },
          { "type": "command", "command": "$HOME/.claude/hooks/ps1.sh" },
          { "type": "command", "command": "$HOME/.claude/hooks/web.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/lint-stop.sh"
          }
        ]
      }
    ]
  }
}
