{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'select(.tool_input.file_path | endswith(\".sh\")) | .tool_input.file_path' | xargs -I{} sh -c 'npx prettier --write --plugin \"$(npm root -g)/prettier-plugin-sh/lib/index.cjs\" {} 2>/dev/null || true'"
          },
          {
            "type": "command",
            "command": "jq -r 'select(.tool_input.file_path | endswith(\".sh\")) | .tool_input.file_path' | xargs -r shellcheck"
          },
          {
            "type": "command",
            "command": "jq -r 'select(.tool_input.file_path | endswith(\".md\")) | .tool_input.file_path' | xargs -r npx prettier --write"
          },
          {
            "type": "command",
            "command": "jq -r 'select(.tool_input.file_path | endswith(\".md\")) | .tool_input.file_path' | xargs -r npx markdownlint-cli2 --config .markdownlint.json"
          },
          {
            "type": "command",
            "command": "jq -r 'select(.tool_input.file_path | endswith(\".ps1\")) | .tool_input.file_path' | xargs -I{} pwsh -Command \"Set-Content '{}' (Invoke-Formatter -ScriptDefinition (Get-Content '{}' -Raw))\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "jq -r 'select(.tool_input.file_path | endswith(\".ps1\")) | .tool_input.file_path' | xargs -I{} pwsh -NoProfile -Command \"Invoke-ScriptAnalyzer -Path '{}' -EnableExit\""
          }
        ]
      }
    ]
  }
}
